# ACIL GÜVENLİK MÜDAHALESI - GEÇİCİ DOSYA
# İşiniz bitince bu dosyayı silin!

# Vercel'den aldığınız DATABASE_URL'i aşağıya yapıştırın:
DATABASE_URL=postgresql://username:password@host:5432/database

# Örnek format:
# DATABASE_URL=postgresql://postgres:yourpassword@db.abc123def456.supabase.co:5432/postgres