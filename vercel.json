{
  "functions": {
    "app/api/admin/products/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    },
    "app/api/admin/products/[id]/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.modabase.com.tr"
        }
      ],
      "destination": "https://modabase.com.tr/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/admin/products",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "env": {
    "NEXT_BODY_SIZE_LIMIT": "100mb"
  }
}
