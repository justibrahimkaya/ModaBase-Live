generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin Status Values: "PENDING", "APPROVED", "REJECTED"
// SQLite doesn't support enums, so using String with constraints

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String? // Şifre hash'i - OAuth kullanıcıları için opsiyonel
  resetToken String?  // Şifre sıfırlama tokeni
  resetTokenExpiry DateTime? // Token geçerlilik süresi
  name      String?
  surname   String?
  phone     String?
  image     String? // Profile image URL for social login
  emailVerified DateTime? // Email verification for NextAuth
  provider  String? // OAuth provider (google, facebook, etc.)
  role      String   @default("USER") // USER, ADMIN, MODERATOR
  
  // Admin Approval System
  adminStatus String? // Admin başvuru durumu (sadece ADMIN rolü için) - "PENDING", "APPROVED", "REJECTED"
  appliedAt   DateTime?    // Admin başvuru tarihi
  approvedAt  DateTime?    // Admin onay tarihi
  rejectedAt  DateTime?    // Admin red tarihi
  rejectionReason String?  // Red nedeni
  businessInfo String?     // İşletme bilgileri (JSON format)
  
  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  addresses Address[]
  orders    Order[]
  reviews   Review[]
  reviewHelpfulVotes ReviewHelpful[]
  cartHistories CartHistory[]
  favorites Favorite[]
  wishlists Wishlist[]
  accounts  Account[]
  sessions  Session[]
  stockNotifications UserStockNotification[]
}

// NextAuth.js Required Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  title       String
  name        String
  surname     String
  email       String
  phone       String
  city        String
  district    String
  neighborhood String
  address     String
  type        String   // DELIVERY veya INVOICE
  isDefault   Boolean  @default(false)
  // E-fatura alanları
  invoiceType String?  // BIREYSEL veya KURUMSAL
  tcKimlikNo  String?  // Bireysel için
  vergiNo     String?  // Kurumsal için
  vergiDairesi String? // Kurumsal için
  companyName String?  // Kurumsal için şirket adı
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  orders      Order[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String? // Büyük resim verileri için
  isActive    Boolean  @default(true)
  parentId    String?  // Ana kategori ID'si (null ise ana kategori)
  businessId  String?  // İşletme ID'si (null ise sistem kategorisi)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  products    Product[]
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  business    Business?  @relation("BusinessCategories", fields: [businessId], references: [id])
  seoSettings SEOSettings? @relation("CategorySEO")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  price        Float
  originalPrice Float?
  images       String // JSON string - büyük veri için
  stock        Int      @default(0)
  minStockLevel Int     @default(5) // Minimum stok seviyesi
  maxStockLevel Int?    // Maksimum stok seviyesi
  reservedStock Int     @default(0) // Rezerve edilmiş stok (sepetteki ürünler)
  categoryId   String
  
  // Gelişmiş SEO Alanları
  metaTitle        String? // Meta title
  metaDescription  String? // Meta description
  keywords         String? // Anahtar kelimeler
  altText          String? // Görsel alt text
  
  // Ürün Detayları
  brand            String? // Marka
  sku              String? // Stok kodu
  gtin             String? // Global Trade Item Number
  mpn              String? // Manufacturer Part Number
  condition        String? // Ürün durumu (new, used, refurbished)
  availability     String? // Stok durumu (in_stock, out_of_stock, preorder)
  material         String? // Malzeme
  color            String? // Renk
  size             String? // Beden
  weight           String? // Ağırlık
  dimensions       String? // Boyutlar
  warranty         String? // Garanti
  countryOfOrigin  String? // Menşei ülke
  
  // Sosyal Medya
  ogTitle          String? // Open Graph title
  ogDescription    String? // Open Graph description
  ogImage          String? // Open Graph image
  ogType           String? // Open Graph type
  twitterCard      String? // Twitter card type
  twitterTitle     String? // Twitter title
  twitterDescription String? // Twitter description
  twitterImage     String? // Twitter image
  
  // Yapılandırılmış Veri
  structuredData   String? // JSON-LD structured data
  canonicalUrl     String? // Canonical URL
  hreflang         String? // Hreflang
  
  // Analitik
  googleAnalyticsId String? // Google Analytics ID
  googleTagManagerId String? // Google Tag Manager ID
  facebookPixelId   String? // Facebook Pixel ID
  
  // Arama Motoru
  robotsMeta        String? // Robots meta
  sitemapPriority   Float?  // Sitemap priority
  changeFrequency   String? // Change frequency
  lastModified      DateTime? // Last modified date
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  category     Category @relation(fields: [categoryId], references: [id])
  reviews      Review[] @relation("ProductReviews")
  orderItems   OrderItem[] @relation("ProductOrderItems")
  cartItems    CartItem[] @relation("ProductCartItems")
  favorites    Favorite[] @relation("ProductFavorites")
  wishlists    Wishlist[] @relation("ProductWishlists")
  stockMovements StockMovement[] @relation("ProductStockMovements")
  variants     ProductVariant[]
  stockNotifications UserStockNotification[] @relation("ProductStockNotifications")
  seoSettings  SEOSettings? @relation("ProductSEO")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  size      String?  // Beden (S, M, L, XL, 36, 37, 38, vs.)
  color     String?  // Renk (Kırmızı, Mavi, vs.)
  colorCode String?  // Renk kodu (#FF0000, #0000FF, vs.)
  stock     Int      @default(0)
  price     Float?   // Farklı fiyat varsa
  sku       String?  // Stok kodu
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId, size, color])
}

model Order {
  id          String   @id @default(cuid())
  userId      String?
  addressId   String?
  invoiceAddressId String?
  status      String   @default("PENDING")
  total       Float
  discount    Float?   // Uygulanan indirim
  shippingCost Float?  // Kargo ücreti
  shippingMethod String? // Kargo tipi
  paymentMethod  String? // Ödeme tipi
  note        String?  // Müşteri notu
  trackingNumber String? // Kargo takip numarası
  shippingCompany String? // Kargo firması
  shippingTrackingUrl String? // Kargo takip URL'i
  shippedAt   DateTime? // Kargo tarihi
  deliveredAt DateTime? // Teslimat tarihi
  adminNotes  String?  // Admin notları
  // Guest checkout için alanlar
  guestName   String?
  guestSurname String?
  guestEmail  String?
  guestPhone  String?
  // E-fatura snapshot alanları
  invoiceType String?  // BIREYSEL veya KURUMSAL
  tcKimlikNo  String?
  vergiNo     String?
  vergiDairesi String?
  unvan       String?
  // E-fatura entegrasyon alanları
  einvoiceStatus String? // PENDING, SUCCESS, ERROR
  einvoiceUuid   String?
  einvoicePdfUrl String?
  einvoiceError  String?
  // İade ve değişim süreçleri için yeni alanlar
  canCancel   Boolean  @default(true) // İptal edilebilir mi?
  canReturn   Boolean  @default(true) // İade edilebilir mi?
  canExchange Boolean  @default(true) // Değişim yapılabilir mi?
  cancelReason String? // İptal nedeni
  returnReason String? // İade nedeni
  exchangeReason String? // Değişim nedeni
  cancelRequestedAt DateTime? // İptal talep tarihi
  returnRequestedAt DateTime? // İade talep tarihi
  exchangeRequestedAt DateTime? // Değişim talep tarihi
  cancelApprovedAt DateTime? // İptal onay tarihi
  returnApprovedAt DateTime? // İade onay tarihi
  exchangeApprovedAt DateTime? // Değişim onay tarihi
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  address     Address? @relation(fields: [addressId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items       OrderItem[]
  stockMovements StockMovement[]
  transferNotifications TransferNotification[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  size      String?
  color     String?
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation("ProductOrderItems", fields: [productId], references: [id], onDelete: Cascade)
  reviews   Review[] // Sipariş kalemi yorumları
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  orderItemId String? // Sadece satın alanlar yorum yazabilsin
  rating    Int      // 1-5 arası rating
  title     String?  // Yorum başlığı
  comment   String?  // Yorum içeriği
  images    String?  // Yorum fotoğrafları (JSON array)
  isApproved Boolean @default(false) // Admin moderasyonu
  isVerifiedPurchase Boolean @default(false) // Doğrulanmış alışveriş
  helpfulCount Int @default(0) // Yararlı oylama sayısı
  unhelpfulCount Int @default(0) // Yararsız oylama sayısı
  adminReply String? // Admin yanıtı
  adminReplyDate DateTime? // Admin yanıt tarihi
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product   Product  @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  helpfulVotes ReviewHelpful[]
  
  @@unique([userId, productId]) // Bir kullanıcı bir ürüne sadece bir kez yorum yapabilir
}

model ReviewHelpful {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  isHelpful Boolean  // true = yararlı, false = yararsız
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@unique([reviewId, userId]) // Bir kullanıcı bir yoruma sadece bir kez oy verebilir
}

model Cart {
  id        String      @id @default(cuid())
  userId    String?     // İleride authentication eklenirse
  isArchived Boolean    @default(false) // Sepet geçmişi için
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     CartItem[]
  cartHistory CartHistory?
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  size      String?
  color     String?
  product   Product  @relation("ProductCartItems", fields: [productId], references: [id], onDelete: Cascade)
  cart      Cart     @relation(fields: [cartId], references: [id])
}

model CartHistory {
  id        String   @id @default(cuid())
  userId    String
  cartId    String   @unique
  name      String   // Kullanıcının verdiği isim (örn: "Alışveriş Listesi 1")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  cart      Cart     @relation(fields: [cartId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation("ProductFavorites", fields: [productId], references: [id], onDelete: Cascade)
  @@unique([userId, productId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation("ProductWishlists", fields: [productId], references: [id], onDelete: Cascade)
  @@unique([userId, productId])
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  orderId     String?
  type        String   // IN, OUT, RESERVED, RELEASED
  quantity    Int
  description String?
  createdAt   DateTime @default(now())
  product     Product  @relation("ProductStockMovements", fields: [productId], references: [id], onDelete: Cascade)
  order       Order?   @relation(fields: [orderId], references: [id])
}

model ShippingCompany {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // API kodu
  apiUrl      String?  // API endpoint
  apiKey      String?  // API anahtarı
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserStockNotification {
  id        String   @id @default(cuid())
  userId    String?  // Kayıtlı kullanıcı için
  guestEmail String? // Misafir kullanıcı için
  productId String
  isActive  Boolean  @default(true)
  notifiedAt DateTime? // Bildirim gönderildiğinde işaretlenir
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation("ProductStockNotifications", fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@unique([guestEmail, productId])
}

model Business {
  id                    String   @id @default(cuid())
  businessName          String
  businessType          String   // limited, anonim, sahis, etc.
  taxNumber             String   @unique
  tradeRegistryNumber   String?
  email                 String   @unique
  phone                 String
  website               String?
  address               String
  city                  String
  district              String?
  postalCode            String?
  contactName           String
  contactSurname        String
  contactTitle          String?
  contactPhone          String?
  contactEmail          String
  password              String
  termsAccepted         Boolean  @default(false)
  privacyAccepted       Boolean  @default(false)
  marketingAccepted     Boolean  @default(false)
  
  // Banka Bilgileri
  bankName              String?  // Banka adı
  bankBranch            String?  // Şube adı
  accountHolderName     String?  // Hesap sahibi adı
  ibanNumber            String?  // IBAN numarası
  accountType           String?  // Hesap türü (TL, USD, EUR)
  
  // İşletme Detayları
  taxOffice             String?  // Vergi dairesi
  registrationDate      DateTime? // Kayıt tarihi
  activityCode          String?  // Faaliyet kodu
  activityDescription   String?  // Faaliyet açıklaması
  
  // Yetkili Kişi Detayları
  contactTcKimlik       String?  // TC Kimlik numarası
  contactBirthDate      DateTime? // Doğum tarihi
  
  // Admin Approval System
  adminStatus           String @default("PENDING") // Approval status - "PENDING", "APPROVED", "REJECTED"
  appliedAt             DateTime @default(now()) // Başvuru tarihi
  approvedAt            DateTime? // Onay tarihi
  rejectedAt            DateTime? // Red tarihi
  rejectionReason       String? // Red nedeni
  approvedBy            String? // Onaylayan admin ID
  
  isActive              Boolean  @default(false)
  emailVerified         Boolean  @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  resetToken            String?
  resetTokenExpiry      DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  transferNotifications TransferNotification[]
  categories            Category[] @relation("BusinessCategories")
}

// SEO Settings Model
model SEOSettings {
  id              String   @id @default(cuid())
  pageType        String   // 'homepage', 'category', 'product', 'general'
  pageId          String?  // Genel page ID (homepage için null)
  productId       String?  // Ürün ID'si (sadece product type için)
  categoryId      String?  // Kategori ID'si (sadece category type için)
  pageSlug        String?  // URL slug (homepage için '/')
  
  // Basic SEO
  metaTitle       String
  metaDescription String
  keywords        String
  
  // Open Graph
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  ogType          String?  // 'website', 'product', 'article'
  
  // Twitter Card
  twitterCard     String?  // 'summary', 'summary_large_image'
  twitterTitle    String?
  twitterDescription String?
  twitterImage    String?
  
  // Structured Data
  structuredData  String?  // JSON formatında schema.org data
  
  // Advanced SEO
  canonicalUrl    String?
  robotsMeta      String?  // 'index,follow', 'noindex,nofollow'
  hreflang        String?  // Çoklu dil desteği için
  
  // Analytics & Tracking
  googleAnalyticsId String?
  googleTagManagerId String?
  facebookPixelId  String?
  
  // Performance
  isActive        Boolean  @default(true)
  priority        Int      @default(0) // Öncelik sırası
  
  // Audit & Monitoring
  lastAuditDate   DateTime?
  seoScore        Int?     // 0-100 arası SEO skoru
  auditNotes      String?  // SEO denetim notları
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  product         Product? @relation("ProductSEO", fields: [productId], references: [id], onDelete: Cascade)
  category        Category? @relation("CategorySEO", fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@unique([pageType, pageId])
  @@unique([pageType, pageSlug])
  @@unique([productId])
  @@unique([categoryId])
}

// Blog Post Model
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   // HTML content
  author      String
  publishedAt DateTime?
  tags        String[] // Array of tags
  image       String   // Featured image URL
  readTime    Int      // Reading time in minutes
  category    String
  viewCount   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // SEO - will be handled via pageId in SEOSettings
  
  @@index([category])
  @@index([publishedAt])
  @@index([isPublished])
}

// Transfer Notification Model (Havale Bildirimleri)
model TransferNotification {
  id              String   @id @default(cuid())
  orderId         String
  customerName    String
  customerEmail   String
  customerPhone   String
  transferAmount  Float
  transferDate    DateTime
  transferNote    String?  // Müşteri notu
  status          String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
  adminNote       String?  // Admin notu
  confirmedAt     DateTime?
  businessId      String
  iban            String
  accountHolder   String
  bankName        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([status])
  @@index([businessId])
}


